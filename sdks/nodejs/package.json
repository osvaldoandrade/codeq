{
  "name": "@osvaldoandrade/codeq-client",
  "version": "1.0.0",
  "description": "Official TypeScript/JavaScript SDK client for CodeQ reactive task scheduling system",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/cjs/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "test": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "codeq",
    "task-queue",
    "scheduling",
    "worker",
    "producer",
    "typescript",
    "sdk"
  ],
  "author": "Osvaldo Andrade",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/osvaldoandrade/codeq.git",
    "directory": "sdks/nodejs"
  },
  "homepage": "https://github.com/osvaldoandrade/codeq/tree/main/sdks/nodejs#readme",
  "bugs": {
    "url": "https://github.com/osvaldoandrade/codeq/issues"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "axios-retry": "^4.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
