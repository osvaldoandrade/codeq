CODEQ_IMAGE=ghcr.io/osvaldoandrade/codeq-service:0.1.0
CODEQ_PORT=8080
CODEQ_ENV=prod
CODEQ_LOG_LEVEL=info

REDIS_ADDR=kvrocks:6666
REDIS_PASSWORD=
KVROCKS_PORT=6666

IDENTITY_SERVICE_URL=https://issuer.example.com
WORKER_JWKS_URL=https://issuer.example.com/.well-known/jwks.json
WORKER_ISSUER=https://issuer.example.com
WORKER_AUDIENCE=codeq-worker
WEBHOOK_HMAC_SECRET=change-me

DEFAULT_LEASE_SECONDS=300
REQUEUE_INSPECT_LIMIT=200
MAX_ATTEMPTS_DEFAULT=5
BACKOFF_POLICY=exp_full_jitter
BACKOFF_BASE_SECONDS=5
BACKOFF_MAX_SECONDS=900

TRACING_ENABLED=false
TRACING_OTLP_ENDPOINT=
TRACING_OTLP_INSECURE=false
TRACING_SAMPLE_RATIO=1.0
